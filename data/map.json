        "description": "晨星银行高级经理"
      },
      {
        "id": "poi-24",
        "label": "洛克哈特",
        "x": 44,
        "y": 88,
        "description": "蓝月小学校长"
      },
      {
        "id": "poi-25",
        "label": "流浪汉罗斯",
        "x": 9,
        "y": 82,
        "description": "在脚型垃圾箱周围乞讨 有自己的情报网"
      },
      {
        "id": "poi-28",
        "label": "马西莫",
        "x": 9,
        "y": 62,
        "description": "五金店老板 钻石老马"
      }
    ]
  }
