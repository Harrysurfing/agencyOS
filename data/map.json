  "pois": {
    "地点": [
      {
        "id": "poi-1",
        "label": "梵高果汁吧",
        "x": 45,
        "y": 50,
        "description": "果汁颜色总像在动。常客说在这里容易想起「不该想起的事」。"
      },
      {
        "id": "poi-2",
        "label": "平反公园",
        "x": 15,
        "y": 12,
        "description": "雕像会悄悄换位置。市政从没承认过，但遛弯的人都知道。"
      },
      {
        "id": "poi-3",
        "label": "户外跳蚤市场",
        "x": 88,
        "y": 42,
        "description": "旧货、怪货、来路不明的货都有。常能淘到「不该存在」的小玩意儿，价格很便宜。"
      },
      {
        "id": "poi-4",
        "label": "霍尔斯顿遛狗公园与会议中心",
        "x": 48,
        "y": 18,
        "description": "狗能进公园，人也能进会议中心——但没人记得谁在隔壁房间开过会。"
      },
      {
        "id": "poi-5",
        "label": "博南扎果汁店",
        "x": 52,
        "y": 48,
        "description": "和梵高果汁吧在同一条街，两家菜单几乎一样，老板从不解释为什么。"
      },
      {
        "id": "poi-6",
        "label": "GraspR 公司总部",
        "x": 92,
        "y": 55,
        "description": "玻璃幕墙、没有Logo、永远在招人。没人能说清他们到底「抓」什么。"
      },
      {
        "id": "poi-7",
        "label": "脚形垃圾箱",
        "x": 10,
        "y": 82,
        "description": "城里唯一一只脚形垃圾箱。清洁工说有时会多出一只「鞋」。"
      },
      {
        "id": "poi-8",
        "label": "玛西亚·马瑟斯音乐厅",
        "x": 48,
        "y": 55,
        "description": "音响极好。有人坚持在晚场听到过从未排演过的第三声部。"
      },
      {
        "id": "poi-9",
        "label": "黑格曼分部图书馆",
        "x": 12,
        "y": 48,
        "description": "分区编号比实际楼层多一层。借书卡上偶尔会出现你没借过的书名。"
      },
      {
        "id": "poi-10",
        "label": "Omni-Mart",
        "x": 50,
        "y": 52,
        "description": "24 小时、什么都有。收银员永远同一张脸，只是胸牌上的名字会变。"
      },
      {
        "id": "poi-11",
        "label": "晨星银行",
        "x": 55,
        "y": 45,
        "description": "老牌、可靠。存钱欢迎，取钱不送。"
      },
      {
        "id": "poi-12",
        "label": "蓝月小学",
        "x": 45,
        "y": 88,
        "description": "升旗仪式准点开始，但操场上影子数量有时对不上人数。"
      },
      {
        "id": "poi-13",
        "label": "马西莫五金店",
        "x": 8,
        "y": 62,
        "description": "螺丝、扳手、锁头一应俱全。老板说「修门」的客人特别多。"
      },
      {
        "id": "poi-14",
        "label": "奥特曼战争纪念馆",
        "x": 72,
        "y": 85,
        "description": "纪念一场官方档案里查不到的「战争」。展品说明经常被涂改。"
      },
      {
        "id": "poi-15",
        "label": "活泼扇贝酒吧",
        "x": 18,
        "y": 88,
        "description": "旧城区情报集散地。扇贝是真的鲜，话题是半真半假。"
      },
      {
        "id": "poi-16",
        "label": "博物馆环路",
        "x": 42,
        "y": 38,
        "description": "像螺旋一样的环线，理论上不该连到全城——但开一圈下来，每个出口都到了你想去的那条街。"
      },
      {
        "id": "poi-17",
        "label": "三连机场",
        "x": 82,
        "y": 8,
        "description": "航班表上的目的地比地图上的城市多。没人追问多出来的那几班飞哪。"
      },
      {
        "id": "poi-18",
        "label": "三连港口",
        "x": 97,
        "y": 75,
        "description": "货轮进出的时间表和潮汐对不上。码头工人说「别算，算不清」。"
      },
      {
        "id": "poi-19",
        "label": "机构总部",
        "x": 52,
        "y": 33,
        "description": "33 层三角大楼，正门也是三角形。外人只到 1 楼接待；楼上几层存在，但电梯按钮没写全。"
      },
      {
        "id": "poi-21",
        "label": "三叶博物馆",
        "x": 44,
        "y": 39,
        "description": "三联城著名博物馆，从上古到未来的展品都有"
      },
      {
        "id": "poi-29",
        "label": "三叉戟赌场",
        "x": 32,
        "y": 7,
        "description": "赌徒与恶棍的天堂"
      }
    ],
    "异常": [
      {
        "id": "poi-26",
        "label": "B1楼层",
        "x": 55,
        "y": 44,
        "description": "银行电梯通往不存在的B1层"
      }
    ],
    "事件": [
      {
